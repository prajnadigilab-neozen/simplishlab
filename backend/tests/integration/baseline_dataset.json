{
    "auth": [
        {
            "id": "AUTH_REG_FAIL_MISSING",
            "name": "Register Fail - Missing Fields",
            "input": {
                "fullName": "Test User",
                "password": "password123"
            },
            "expectedStatus": 400,
            "expectedBody": {
                "message": "Full name, password, and either email or phone are required"
            }
        },
        {
            "id": "AUTH_REG_SUCCESS",
            "name": "Register Success",
            "input": {
                "fullName": "Jane Doe",
                "phone": "+919876543210",
                "password": "SecurePassword123"
            },
            "expectedStatus": 201,
            "matchPath": "message",
            "expectedValue": "Registration successful."
        },
        {
            "id": "AUTH_LOGIN_FAIL",
            "name": "Login Fail - Invalid Credentials",
            "input": {
                "email": "wrong@example.com",
                "password": "wrongpassword"
            },
            "expectedStatus": 401
        }
    ],
